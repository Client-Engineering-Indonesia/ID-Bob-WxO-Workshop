# watsonx Orchestrate Configuration
WXO_API_KEY=your_api_key_here
WXO_INSTANCE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/your_instance_id

# Optional: Yahoo Finance API (if using premium features)
# YAHOO_FINANCE_API_KEY=your_yahoo_api_key_here

# News Scraper Configuration
NEWS_SOURCES=yahoo_finance,reuters
MAX_NEWS_ARTICLES=10
SENTIMENT_THRESHOLD=0.5

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=wxo-financial-agent.log
